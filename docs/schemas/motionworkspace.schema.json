{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://motionmatching.studio/schemas/motionworkspace.schema.json",
  "title": "MotionMatching Studio Workspace Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "name",
    "mode",
    "characters"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^wrk_[a-f0-9]{12}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "const": "browser"
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "manifestPath"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^chr_[a-f0-9]{12}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "manifestPath": {
            "type": "string",
            "pattern": "^[^/\\\\]+/.+\\.json$"
          }
        }
      }
    }
  }
}
