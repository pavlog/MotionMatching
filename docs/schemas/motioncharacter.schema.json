{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://motionmatching.studio/schemas/motioncharacter.schema.json",
  "title": "MotionMatching Studio Character Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "name",
    "visualManifestPath",
    "clipManifestPaths"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^chr_[a-f0-9]{12}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "visualManifestPath": {
      "const": "Visual/visual.json"
    },
    "clipManifestPaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "samplings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "capsule",
          "facing",
          "velocity",
          "trajectory"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^smp_[a-f0-9]{12}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "capsule": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "height",
              "radius"
            ],
            "properties": {
              "height": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "radius": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            }
          },
          "facing": {
            "$ref": "#/$defs/vector3"
          },
          "velocity": {
            "$ref": "#/$defs/vector3"
          },
          "trajectory": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "frameOffset",
                "position",
                "direction"
              ],
              "properties": {
                "frameOffset": {
                  "type": "integer",
                  "minimum": 1
                },
                "position": {
                  "$ref": "#/$defs/vector3"
                },
                "direction": {
                  "$ref": "#/$defs/vector3"
                },
                "speedMode": {
                  "enum": [
                    "auto",
                    "manual"
                  ]
                },
                "speed": {
                  "type": [
                    "number",
                    "null"
                  ],
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    },
    "runtimeBuildSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sampleFrameStep",
        "scaleMode",
        "trajectoryPredictionFrames"
      ],
      "properties": {
        "sampleFrameStep": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "scaleMode": {
          "enum": [
            "auto",
            "source_x0_01",
            "character_x1"
          ]
        },
        "trajectoryPredictionFrames": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 600
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "vector3": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    }
  }
}
