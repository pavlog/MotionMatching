{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://motionmatching.studio/schemas/motionvisual.schema.json",
  "title": "MotionMatching Studio Visual Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "sourceFileName",
    "managedSourcePath",
    "sourceFileSizeBytes",
    "importedAtUtc"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^vis_[a-f0-9]{12}$"
    },
    "sourceFileName": {
      "type": "string",
      "pattern": "^[^/\\\\]+\\.fbx$"
    },
    "managedSourcePath": {
      "const": "Visual/source.fbx"
    },
    "sourceFileSizeBytes": {
      "type": "integer",
      "minimum": 0
    },
    "importedAtUtc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
